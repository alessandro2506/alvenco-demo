# Resend — https://resend.com/api-keys (non committare mai la chiave reale)
RESEND_API_KEY=

# Destinatario delle richieste dal form (la tua casella di lavoro)
CONTACT_TO_EMAIL=

# Mittente: con dominio verificato su Resend, es. contatti@tuodominio.com
# In test puoi usare spesso: onboarding@resend.dev (vedi documentazione Resend)
RESEND_FROM_EMAIL=

# DeepL — solo per script locale: npm run i18n:deepl (rigenera messages/en.json da it.json)
# https://www.deepl.com/pro-api — non committare la chiave
DEEPL_AUTH_KEY=
