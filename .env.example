# SMTP Aruba — smtps.aruba.it (non committare mai le password)
SMTP_USER=
SMTP_PASS=

# Casella dedicata per auto-reply al cliente (mittente no-reply)
SMTP_NOREPLY_USER=
SMTP_NOREPLY_PASS=

# Destinatario delle richieste dal form (solitamente la stessa casella o una inbox team)
CONTACT_TO_EMAIL=

# DeepL — solo per script locale: npm run i18n:deepl (rigenera messages/en.json da it.json)
# https://www.deepl.com/pro-api — non committare la chiave
DEEPL_AUTH_KEY=
